{
  "rewrites": [
    { "source": "/onboarding", "destination": "/app/index.html" },
    { "source": "/dashboard", "destination": "/app/index.html" },
    { "source": "/wizard", "destination": "/app/index.html" },
    { "source": "/check-in", "destination": "/app/index.html" },
    { "source": "/learn", "destination": "/app/index.html" },
    { "source": "/settings", "destination": "/app/index.html" },
    { "source": "/privacy", "destination": "/app/index.html" },
    { "source": "/terms", "destination": "/app/index.html" },
    { "source": "/app/assets/(.*)", "destination": "/app/assets/$1" },
    { "source": "/app/(.*)", "destination": "/app/index.html" }
  ]
}
